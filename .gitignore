node_modules/
config.json
games.json
clip-prep.log
*.bak

# Visual brainstorming workspace (transient mockups)
.superpowers/

# OBS bundles — exported user config, never commit (may contain personal paths/settings)
New folder/
obs-export/
obs-export-*/
*-bundle/
# ... EXCEPT Overlay/default-bundle/ — vendored once via dashboard export,
# auto-imports on fresh-OBS installs so iex becomes one-click.
!Overlay/default-bundle/
!Overlay/default-bundle/**

# Hard re-deny credential-shaped files anywhere under default-bundle/.
# OBS exports include OAuth refresh tokens (basic.ini in profile dirs),
# stream-key files (service.json), API keys (legacy secrets.js inside
# old-layout overlays). Belt-and-braces: even if someone re-vendors a
# bundle without scrubbing, these patterns won't make it into git.
Overlay/default-bundle/**/basic.ini
Overlay/default-bundle/**/service.json
Overlay/default-bundle/**/secrets.js

# Overlay secrets (API keys) — never commit
Overlay/sasi-secrets.js
Overlay/sasi-overlays/secrets.js
Overlay/sasi-overlays/lib/secrets.js

# Loose dump folders from drag-and-drop accidents (fresh OBS bundle exports
# should land at a chosen output dir, not the repo root)
/Overlays/
* (2)*
